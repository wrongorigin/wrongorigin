<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {% endif %}WRONGORIGIN</title>
  <meta name="description" content="{{ description or 'WRONGORIGIN — Photography' }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;1,300;1,400&family=Syne:wght@400;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/wrongorigin/css/main.css" />
</head>
<body>

  <nav class="nav">
    <a href="/" class="nav__logo">WRONGORIGIN</a>
    <ul class="nav__links">
      <li><a href="/projects/" class="nav__link">Work</a></li>
      <li><a href="/about/" class="nav__link">About</a></li>
    </ul>
  </nav>

  <main>
    {{ content | safe }}
  </main>

  <footer class="footer">
    <p class="footer__copy">&copy; {{ date | default('2025') }} WRONGORIGIN. All rights reserved.</p>
    <p class="footer__tagline">Images made in the dark.</p>
  </footer>

  <script src="/wrongorigin/js/main.js"></script>
</body>
</html>
